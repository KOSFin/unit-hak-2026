COMPOSE_PROJECT_NAME=flowboard

FRONTEND_PUBLIC_URL=https://flowboard.example.com
BACKEND_PUBLIC_URL=https://api.flowboard.example.com

FRONTEND_INTERNAL_PORT=3000
BACKEND_INTERNAL_PORT=8000

VITE_API_BASE_URL=https://api.flowboard.example.com
VITE_WS_URL=wss://api.flowboard.example.com/ws

POSTGRES_DB=flowboard
POSTGRES_USER=flowboard
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://flowboard:change_me_strong_password@postgres:5432/flowboard

RABBITMQ_DEFAULT_USER=flowboard
RABBITMQ_DEFAULT_PASS=change_me_strong_password
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_URL=amqp://flowboard:change_me_strong_password@rabbitmq:5672/

BACKEND_CORS_ORIGINS=https://flowboard.example.com
APP_ENV=production
LOG_LEVEL=info

JWT_SECRET=change_me_even_if_auth_is_simple
SEED_DEMO_DATA=true
UPLOADS_PATH=/app/uploads
