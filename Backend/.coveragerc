[run]
branch = True
source = app
omit =
    app/__init__.py
    app/core/__init__.py
    app/api/__init__.py
    app/realtime/__init__.py
    app/queue/__init__.py
    app/models/__init__.py
    app/schemas/__init__.py
    app/repositories/__init__.py
    app/services/__init__.py
    alembic/*
    */migrations/*

[report]
show_missing = True
skip_empty = True
